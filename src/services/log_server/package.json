  },
  "dependencies": {
    "sql.js": "^1.10.2",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "livereload": "^0.9.3"
  }
}
