<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/openOrderIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle_open"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_send"
            android:tint="@color/ink_900"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/openOrderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ORD-0000"
            android:textStyle="bold"
            android:textColor="@color/ink_900"
            app:layout_constraintTop_toTopOf="@id/openOrderIcon"
            app:layout_constraintStart_toEndOf="@id/openOrderIcon"
            app:layout_constraintEnd_toStartOf="@id/openOrderAmount"
            android:layout_marginStart="12dp" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/openOrderTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2026-01-01"
            android:textColor="@color/stone_400"
            app:layout_constraintTop_toBottomOf="@id/openOrderId"
            app:layout_constraintStart_toStartOf="@id/openOrderId"
            app:layout_constraintEnd_toStartOf="@id/openOrderAmount" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/openOrderAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INR 0.00"
            android:textColor="@color/ink_900"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/openOrderId"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/openOrderMetaRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/openOrderTime"
            app:layout_constraintStart_toStartOf="@id/openOrderId"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openOrderClaim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Claim"
                android:textColor="@color/ivory_50"
                app:backgroundTint="@color/ink_900"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/openOrderDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stone_200" />

</LinearLayout>
