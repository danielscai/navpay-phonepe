<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/orderIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:tint="@color/ink_900"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="ORD-0000"
            android:textStyle="bold"
            android:textColor="@color/ink_900"
            app:layout_constraintTop_toTopOf="@id/orderIcon"
            app:layout_constraintStart_toEndOf="@id/orderIcon"
            app:layout_constraintEnd_toStartOf="@id/orderAmount"
            android:layout_marginStart="12dp" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2026-01-01"
            android:textColor="@color/stone_400"
            app:layout_constraintTop_toBottomOf="@id/orderId"
            app:layout_constraintStart_toStartOf="@id/orderId"
            app:layout_constraintEnd_toStartOf="@id/orderAmount" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INR 0.00"
            android:textColor="@color/ink_900"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/orderId"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="PAID"
            android:textColor="@color/white"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/status_badge"
            app:layout_constraintTop_toBottomOf="@id/orderAmount"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderApp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="App: PE"
            android:textColor="@color/stone_400"
            app:layout_constraintTop_toBottomOf="@id/orderTime"
            app:layout_constraintStart_toStartOf="@id/orderId"
            app:layout_constraintEnd_toStartOf="@id/orderStatus" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/orderCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textStyle="bold"
            android:textColor="@color/ink_900"
            app:layout_constraintTop_toBottomOf="@id/orderStatus"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/orderDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stone_200" />

</LinearLayout>
