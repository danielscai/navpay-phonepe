<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <ImageView
            android:id="@+id/earningIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_save"
            android:tint="@color/ink_900"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/earningId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="EARN-0000"
            android:textStyle="bold"
            android:textColor="@color/ink_900"
            app:layout_constraintTop_toTopOf="@id/earningIcon"
            app:layout_constraintStart_toEndOf="@id/earningIcon"
            app:layout_constraintEnd_toStartOf="@id/earningAmount"
            android:layout_marginStart="12dp" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/earningNote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Note"
            android:textColor="@color/stone_400"
            app:layout_constraintTop_toBottomOf="@id/earningId"
            app:layout_constraintStart_toStartOf="@id/earningId"
            app:layout_constraintEnd_toStartOf="@id/earningAmount" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/earningAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INR 0.00"
            android:textColor="@color/ink_900"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/earningId"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/earningTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="2026-01-01"
            android:textColor="@color/stone_400"
            app:layout_constraintTop_toBottomOf="@id/earningAmount"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/earningDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stone_200" />

</LinearLayout>
