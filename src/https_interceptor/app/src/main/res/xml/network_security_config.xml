<?xml version="1.0" encoding="utf-8"?>
<!--
    网络安全配置
    用于安全研究目的，允许拦截和分析 HTTPS 流量

    警告：此配置会降低应用的安全性，仅用于研究环境
-->
<network-security-config>
    <!-- 允许明文 HTTP 流量（用于测试） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <!-- 信任系统证书 -->
            <certificates src="system" />
            <!-- 信任用户安装的证书（用于 Charles/Fiddler 等代理工具） -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- 调试模式下信任用户证书 -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
