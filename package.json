{
  "name": "indipay-apk-research",
  "private": true,
  "packageManager": "yarn@4.0.0",
  "scripts": {
    "1": "./tools/step1_verify_extract_apk.sh",
    "2": "./tools/step2_verify_merge_apk.sh",
    "3": "./tools/step3_verify_signature_bypass.sh",
    "4": "./tools/step4_verify_injection.sh",
    "6": "./tools/step6_verify_phonepehelper.sh",
    "login": "./tools/step5_auto_login.sh",
    "nologin": "./tools/step5_auto_login.sh --no-proceed",
    "res": "./tools/restart_app.sh",
    "logs": "./tools/step4_view_http_logs.sh",
    "logs:crash": "adb logcat | grep -i -E \"(FATAL EXCEPTION|AndroidRuntime|SIGABRT|SIGSEGV|CRASH)\"",
    "emu": "/Users/danielscai/Library/Android/sdk/emulator/emulator @phonepe1",
    "patch:phonepehelper": "./tools/patch_phonepehelper.sh",
    "orch:graph": "python3 src/build-orchestrator/orchestrator.py graph",
    "orch:status": "python3 src/build-orchestrator/orchestrator.py status",
    "orch:reset": "python3 src/build-orchestrator/orchestrator.py reset",
    "orch:rebuild": "python3 src/build-orchestrator/orchestrator.py rebuild",
    "orch:merge": "python3 src/build-orchestrator/orchestrator.py rebuild --only phonepe_merged",
    "orch:decomp": "python3 src/build-orchestrator/orchestrator.py rebuild --only phonepe_decompiled",
    "orch:plan": "python3 src/build-orchestrator/orchestrator.py plan",
    "orch:pre-cache": "python3 src/build-orchestrator/orchestrator.py pre-cache",
    "orch:build-modules": "python3 src/build-orchestrator/orchestrator.py build-modules",
    "orch:inject": "python3 src/build-orchestrator/orchestrator.py inject",
    "orch:compile": "python3 src/build-orchestrator/orchestrator.py compile",
    "orch:compile:reuse": "python3 src/build-orchestrator/orchestrator.py compile --reuse-artifacts",
    "orch:test": "python3 src/build-orchestrator/orchestrator.py test",
    "orch:test:smoke": "python3 src/build-orchestrator/orchestrator.py test --smoke",
    "orch:test:sigbypass": "python3 src/build-orchestrator/orchestrator.py test --profile sigbypass-only --smoke",
    "orch:test:https": "python3 src/build-orchestrator/orchestrator.py test --profile https-only --smoke",
    "orch:test:phonepehelper": "python3 src/build-orchestrator/orchestrator.py test --profile phonepehelper-only --smoke",
    "apk:archive": "./src/tools/archive_apk.sh",
    "baseline:archive": "./src/tools/archive_apk.sh --label baseline",
    "probe": "./src/tools/behavior_probe.sh",
    "probe:baseline": "bash -lc 'if [ -z \"${BASELINE_RUN_DIR:-}\" ]; then echo \"BASELINE_RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$BASELINE_RUN_DIR\" \"$@\"' --",
    "probe:candidate": "bash -lc 'if [ -z \"${CANDIDATE_RUN_DIR:-}\" ]; then echo \"CANDIDATE_RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$CANDIDATE_RUN_DIR\" \"$@\"' --",
    "probe:compare": "./src/tools/compare_behavior.sh",
    "artifact:archive": "./src/tools/archive_apk.sh",
    "artifact:probe": "./src/tools/behavior_probe.sh",
    "artifact:compare": "./src/tools/compare_behavior.sh",
    "artifact:probe:archive": "bash -lc 'if [ -z \"${RUN_DIR:-}\" ]; then echo \"RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$RUN_DIR\" \"$@\"' --",
    "test:smoke:full": "yarn orch:test:smoke",
    "test:independent": "bash src/tools/test_module_independent.sh",
    "test:full": "yarn orch:test"
  }
}
