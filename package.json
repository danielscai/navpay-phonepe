{
  "name": "indipay-apk-research",
  "private": true,
  "packageManager": "yarn@4.0.0",
  "scripts": {
    "1": "./tools/step1_verify_extract_apk.sh",
    "2": "./tools/step2_verify_merge_apk.sh",
    "3": "./tools/step3_verify_signature_bypass.sh",
    "4": "./tools/step4_verify_injection.sh",
    "6": "./tools/step6_verify_phonepehelper.sh",
    "login": "./tools/step5_auto_login.sh",
    "nologin": "./tools/step5_auto_login.sh --no-proceed",
    "res": "./tools/restart_app.sh",
    "logs": "./tools/step4_view_http_logs.sh",
    "logs:crash": "adb logcat | grep -i -E \"(FATAL EXCEPTION|AndroidRuntime|SIGABRT|SIGSEGV|CRASH)\"",
    "emu": "/Users/danielscai/Library/Android/sdk/emulator/emulator @phonepe1",
    "patch:phonepehelper": "./tools/patch_phonepehelper.sh",
    "graph": "python3 src/cache-manager/orchestrator.py graph",
    "status": "python3 src/cache-manager/orchestrator.py status",
    "reset": "python3 src/cache-manager/orchestrator.py reset",
    "rebuild": "python3 src/cache-manager/orchestrator.py rebuild",
    "rebuild-only": "python3 src/cache-manager/orchestrator.py rebuild --only",
    "merge": "python3 src/cache-manager/orchestrator.py rebuild --only phonepe_merged",
    "decomp": "python3 src/cache-manager/orchestrator.py rebuild --only phonepe_decompiled",
    "sigbypass": "python3 src/cache-manager/orchestrator.py sigbypass",
    "https": "python3 src/cache-manager/orchestrator.py https",
    "pehelp": "python3 src/cache-manager/orchestrator.py phonepehelper",
    "apk:archive": "./src/tools/archive_apk.sh",
    "baseline:archive": "./src/tools/archive_apk.sh --label baseline",
    "probe": "./src/tools/behavior_probe.sh",
    "probe:baseline": "bash -lc 'if [ -z \"${BASELINE_RUN_DIR:-}\" ]; then echo \"BASELINE_RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$BASELINE_RUN_DIR\" \"$@\"' --",
    "probe:candidate": "bash -lc 'if [ -z \"${CANDIDATE_RUN_DIR:-}\" ]; then echo \"CANDIDATE_RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$CANDIDATE_RUN_DIR\" \"$@\"' --",
    "probe:compare": "./src/tools/compare_behavior.sh",
    "artifact:archive": "./src/tools/archive_apk.sh",
    "artifact:probe": "./src/tools/behavior_probe.sh",
    "artifact:compare": "./src/tools/compare_behavior.sh",
    "artifact:probe:archive": "bash -lc 'if [ -z \"${RUN_DIR:-}\" ]; then echo \"RUN_DIR is required\" >&2; exit 1; fi; ./src/tools/behavior_probe.sh --output \"$RUN_DIR\" \"$@\"' --",
    "test:smoke:full": "bash src/tools/test_profile_smoke.sh full",
    "test:independent": "bash src/tools/test_module_independent.sh",
    "test:indep": "bash src/tools/test_module_independent.sh",
    "test:full": "bash src/tools/test_profile_full.sh"
  }
}
