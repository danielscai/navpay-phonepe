{
  "name": "indipay-apk-research",
  "private": true,
  "packageManager": "yarn@4.0.0",
  "scripts": {
    "logs:crash": "adb logcat | grep -i -E \"(FATAL EXCEPTION|AndroidRuntime|SIGABRT|SIGSEGV|CRASH)\"",
    "emu": "/Users/danielscai/Library/Android/sdk/emulator/emulator @phonepe1",
    "flow:plan": "python3 src/orch/orchestrator.py plan",
    "flow:pre-cache": "python3 src/orch/orchestrator.py pre-cache",
    "flow:compile-modules": "python3 src/orch/orchestrator.py compile-modules",
    "flow:merge": "python3 src/orch/orchestrator.py merge",
    "flow:compile": "python3 src/orch/orchestrator.py compile",
    "flow:compile:reuse": "python3 src/orch/orchestrator.py compile --reuse-artifacts",
    "flow:test": "python3 src/orch/orchestrator.py test",
    "flow:test:smoke": "python3 src/orch/orchestrator.py test --smoke",
    "flow:test:sigbypass": "python3 src/orch/orchestrator.py test --profile sigbypass-only --smoke",
    "flow:test:https": "python3 src/orch/orchestrator.py test --profile https-only --smoke",
    "flow:test:phonepehelper": "python3 src/orch/orchestrator.py test --profile phonepehelper-only --smoke",
    "orch:graph": "python3 src/orch/orchestrator.py graph",
    "orch:status": "python3 src/orch/orchestrator.py status",
    "orch:reset": "python3 src/orch/orchestrator.py reset",
    "orch:rebuild": "python3 src/orch/orchestrator.py rebuild",
    "orch:rebuild:merged": "python3 src/orch/orchestrator.py rebuild --only phonepe_merged",
    "orch:rebuild:decompiled": "python3 src/orch/orchestrator.py rebuild --only phonepe_decompiled",
    "test:smoke:full": "yarn flow:test:smoke",
    "test:full": "yarn flow:test"
  }
}
